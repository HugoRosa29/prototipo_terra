<?xml version="1.0" encoding="utf-8"?>
<extension version="3.10.11" type="template" client="site">
	<name>terracap</name>
	<creationDate>2026-07-10</creationDate>
	<author>Terracap</author>
	<authorEmail>ti@terracap.df.gov.br</authorEmail>
	<authorUrl>https://www.terracap.df.gov.br</authorUrl>
	<copyright>Copyright (C) Terracap. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later</license>
	<version>1.0.0</version>
	<description>Template institucional Terracap — "Eixos Curvas", convertido do protótipo estático para Joomla 3.1 com posições de módulo editáveis.</description>

	<files>
		<filename>index.php</filename>
		<filename>templateDetails.xml</filename>
		<filename>favicon.ico</filename>
		<folder>css</folder>
		<folder>js</folder>
		<folder>img</folder>
		<folder>language</folder>
	</files>

	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.tpl_terracap.ini</language>
		<language tag="en-GB">en-GB/en-GB.tpl_terracap.sys.ini</language>
		<language tag="pt-BR">pt-BR/pt-BR.tpl_terracap.ini</language>
		<language tag="pt-BR">pt-BR/pt-BR.tpl_terracap.sys.ini</language>
	</languages>

	<positions>
		<position>mega-terracap</position>
		<position>mega-servicos</position>
		<position>mega-imprensa</position>
		<position>hero</position>
		<position>indicadores</position>
		<position>territorio</position>
		<position>compre</position>
		<position>regularize</position>
		<position>servicos</position>
		<position>invista</position>
		<position>transparencia</position>
		<position>atualizacoes</position>
		<position>footer</position>
		<position>debug</position>
	</positions>

	<config>
		<fields name="params">
			<fieldset name="advanced">
				<field
					name="chatUrl"
					type="text"
					default="https://terracap.chat.comunix.tech/chat-externo"
					label="URL do chat on-line"
					description="Link usado pelo botão flutuante de chat no canto da página."
				/>
			</fieldset>
		</fields>
	</config>
</extension>
